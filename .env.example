APP_DOMAIN=youtubepilot.example.com
POSTGRES_DB=youtubepilot
POSTGRES_USER=youtubepilot
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
SESSION_SECRET=replace-with-at-least-64-random-characters
SESSION_ENCRYPTION_KEY=replace-with-32-byte-base64-key
SIGNUP_INVITE_CODE=replace-with-a-private-customer-invitation-code
WORKER_INTERVAL_SECONDS=20
WORKER_CONCURRENCY=1
MAX_VIDEO_MB=1000
MAX_IMAGE_MB=10
MAX_CAPTION_MB=5
MAX_EXCEL_MB=10
MAX_STORAGE_MB_PER_USER=4096
LOGIN_SESSION_MINUTES=20
BROWSER_HEADLESS=true
BROWSER_PROFILE_ROOT=/app/storage/browser-profiles
YOUTUBE_STUDIO_URL=https://studio.youtube.com/
VISIBLE_CHROME_PATH=/usr/bin/google-chrome-stable
