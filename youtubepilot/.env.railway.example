# Add DATABASE_URL as a Railway reference variable from the PostgreSQL service.
NODE_ENV=production
COOKIE_SECURE=true
TRUST_PROXY=true
SESSION_SECRET=replace-with-at-least-64-random-characters
SESSION_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
SIGNUP_INVITE_CODE=replace-with-a-private-invite-code
WORKER_INTERVAL_SECONDS=20
WORKER_CONCURRENCY=1
MAX_VIDEO_MB=250
MAX_IMAGE_MB=10
MAX_CAPTION_MB=5
MAX_EXCEL_MB=10
MAX_STORAGE_MB_PER_USER=400
LOGIN_SESSION_MINUTES=20
BROWSER_HEADLESS=false
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=Asia/Kolkata
RAILWAY_SHM_SIZE_BYTES=268435456
RAILWAY_DEPLOYMENT_DRAINING_SECONDS=30
