<%- include('partials/head') %>
<main class="auth-shell">
  <section class="cinema-auth"><canvas data-creator-universe aria-hidden="true"></canvas><div class="scan-beam"></div><div class="cinema-grid"></div><div class="auth-brand"><span class="brand-mark large"><span></span></span><strong>YouTubePilot</strong></div><div class="auth-hero"><p class="eyebrow">Build your publishing runway</p><h1>From upload<br><span>to impact.</span></h1><p>One private workspace for media, metadata, scheduling, resilient browser automation and accountable errors.</p><div class="auth-metrics"><span><b>Video</b> long-form</span><span><b>Shorts</b> vertical</span><span><b>Excel</b> bulk planning</span></div></div><div class="vfx-stage auth-vfx" aria-hidden="true"><div class="orbit orbit-a"></div><div class="orbit orbit-b"></div><div class="play-core"><span></span></div><div class="floating-card card-a"><b>UPLOAD</b><i></i><small>ENCRYPTED</small></div><div class="floating-card card-b"><b>QUEUE</b><i></i><small>ONLINE</small></div></div></section>
  <section class="auth-panel"><div class="auth-card"><p class="eyebrow dark">Invitation onboarding</p><h2>Create your studio</h2><p class="muted">Use at least 12 characters for your account password.</p><%- include('partials/flash') %><form class="stack-form" method="post" action="/register"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label><span>Display name</span><input name="displayName" maxlength="80" required autocomplete="name"></label><label><span>Email address</span><input type="email" name="email" maxlength="254" required autocomplete="email"></label><label><span>Password</span><input type="password" name="password" minlength="12" required autocomplete="new-password"></label><label><span>Confirm password</span><input type="password" name="confirmPassword" required autocomplete="new-password"></label><% if (inviteRequired) { %><label><span>Customer invitation code</span><input type="password" name="invitationCode" required autocomplete="off"></label><% } else { %><input type="hidden" name="invitationCode" value=""><% } %><button class="btn btn-primary btn-xl" type="submit">Create command center <i>→</i></button></form><p class="auth-switch">Already registered? <a href="/login">Sign in</a></p></div></section>
</main><%- include('partials/footer') %>
