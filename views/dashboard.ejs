<%
  const timeValue = (value, fallback) => /^\d{2}:\d{2}/.test(String(value || '')) ? String(value).slice(0,5) : fallback;
%>
<%- include('partials/head') %>
<link rel="stylesheet" href="/assets/cinematic-login.css?v=20260722-dashboard-fix">
<%- include('partials/nav') %>
<div class="app-shell">
  <aside class="sidebar">
    <nav>
      <a href="#overview" class="active">Overview</a><a href="#channel">Channel</a><a href="#composer">Create</a><a href="#library">Media</a><a href="#queue">Queue</a><a href="#settings">Settings</a><a href="#activity">Activity</a>
    </nav>
    <div class="sidebar-status"><span class="live-dot"></span><div><strong>Backend worker</strong><small>Runs without client laptop</small></div></div>
  </aside>
  <main class="content">
    <%- include('partials/flash') %>
    <section id="overview" class="cinema-hero dashboard-cinema">
      <canvas data-creator-universe aria-hidden="true"></canvas>
      <div class="scan-beam"></div><div class="cinema-grid"></div>
      <div class="hero-copy"><p class="eyebrow">Creator command center</p><h1>Your channel,<br><span>always in motion.</span></h1><p>Upload once. Schedule precisely. Let the encrypted backend studio publish Videos and Shorts while every customer device is offline.</p><div class="hero-actions"><a class="btn btn-primary btn-lg" href="#composer">Create release <i>↗</i></a><a class="btn btn-glass btn-lg" href="#queue">Inspect queue</a></div></div>
      <div class="vfx-stage" aria-hidden="true"><div class="orbit orbit-a"></div><div class="orbit orbit-b"></div><div class="play-core"><span></span></div><div class="floating-card card-a"><b>SHORT</b><i></i><small>00:27</small></div><div class="floating-card card-b"><b>4K VIDEO</b><i></i><small>12:48</small></div><div class="timeline-vfx"><span></span><em></em></div></div>
    </section>

    <section class="stats-grid">
      <article><span>Total missions</span><strong><%= counts.total %></strong><small><%= counts.videos %> videos · <%= counts.shorts %> shorts</small></article>
      <article><span>Ready</span><strong><%= counts.ready %></strong><small>Awaiting scheduled start</small></article>
      <article><span>Uploaded</span><strong><%= counts.uploaded %></strong><small>Completed by backend</small></article>
      <article class="<%= counts.attention ? 'stat-alert' : '' %>"><span>Needs attention</span><strong><%= counts.attention %></strong><small>Review login or result</small></article>
    </section>

    <section id="channel" class="panel channel-panel">
      <div class="section-heading"><div><p class="eyebrow">Encrypted connection</p><h2>YouTube channel</h2></div><span class="status-pill status-<%= (account?.status || 'DISCONNECTED').toLowerCase() %>"><%= account?.status || 'DISCONNECTED' %></span></div>
      <div class="channel-grid"><div class="channel-identity"><div class="youtube-orb"><span></span></div><div><strong><%= account?.channel_name || 'No channel connected' %></strong><p><%= account?.status === 'CONNECTED' ? 'Session state is encrypted with AES-256-GCM. Your Google password is never stored.' : 'Connect through the isolated remote YouTube Studio browser once.' %></p><% if (account?.last_error) { %><small class="error-copy"><%= account.last_error %></small><% } %></div></div><div class="channel-actions"><% if (account?.status === 'CONNECTED') { %><form method="post" action="/app/youtube/disconnect" data-confirm="Disconnect and erase the encrypted YouTube session?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-danger" type="submit">Disconnect</button></form><% } else { %><form method="post" action="/app/youtube/connect"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="btn btn-primary" type="submit">Connect YouTube Studio</button></form><% } %></div></div>
    </section>

    <section id="composer" class="panel composer-panel"><%- include('partials/upload-form',{ item:null,editMode:false,media,settings,automationDate:'',automationTime:'',publishDate:'',publishTime:'' }) %></section>

    <section id="library" class="panel">
      <div class="section-heading"><div><p class="eyebrow">Private object vault</p><h2>Media library</h2><p><%= formatBytes(storageUsedBytes) %> of <%= formatBytes(appLimits.maxStorageBytesPerUser) %> used</p></div><a class="btn btn-ghost" href="/app/export-excel">Export Excel</a></div>
      <div class="upload-decks">
        <% [['VIDEO','Videos','MP4, MOV, WebM or MKV'],['THUMBNAIL','Thumbnails','JPG, PNG or WebP'],['CAPTION','Captions','SRT or VTT']].forEach(([kind,label,hint]) => { %>
        <form class="drop-card" method="post" action="/app/media/<%= kind %>" enctype="multipart/form-data"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label for="files-<%= kind %>"><span class="drop-icon"><%= kind === 'VIDEO' ? '▶' : kind === 'THUMBNAIL' ? '▧' : 'CC' %></span><strong>Upload <%= label %></strong><small><%= hint %></small><em>Choose files</em></label><input id="files-<%= kind %>" type="file" name="files" multiple required accept="<%= kind === 'VIDEO' ? 'video/*' : kind === 'THUMBNAIL' ? 'image/jpeg,image/png,image/webp' : '.srt,.vtt' %>"><button class="btn btn-dark" type="submit">Secure upload</button></form>
        <% }) %>
      </div>
      <div class="media-list"><% media.forEach(file => { %><article><span class="file-kind"><%= file.kind.slice(0,2) %></span><div><strong><%= file.original_name %></strong><small><%= file.kind %> · <%= formatBytes(file.size_bytes) %></small></div><div class="row-actions"><a href="/app/media/<%= file.id %>/download">Download</a><form method="post" action="/app/media/<%= file.id %>/delete" data-confirm="Delete this private file?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit">Delete</button></form></div></article><% }) %><% if (!media.length) { %><div class="empty-state">Your private media vault is empty.</div><% } %></div>
      <form class="excel-import" method="post" action="/app/import-excel" enctype="multipart/form-data"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div><strong>Import upload plan</strong><small>Use the included Videos and Shorts Excel sheets.</small></div><input type="file" name="excel" accept=".xlsx" required><button class="btn btn-secondary" type="submit">Import Excel</button></form>
    </section>

    <section id="queue" class="panel">
      <div class="section-heading"><div><p class="eyebrow">Live publishing runway</p><h2>Upload queue</h2></div><div class="queue-switch" data-queue-switch><button class="active" data-filter="ALL">All</button><button data-filter="VIDEO">Videos</button><button data-filter="SHORT">Shorts</button></div></div>
      <div class="queue-list"><% uploads.forEach(item => { %><article class="queue-card" data-content-type="<%= item.content_type %>"><div class="queue-thumbnail <%= item.content_type.toLowerCase() %>"><span><%= item.content_type === 'SHORT' ? '▯' : '▶' %></span></div><div class="queue-main"><div class="queue-title"><span class="type-chip"><%= item.content_type %></span><h3><%= item.title %></h3><span class="status-pill status-<%= item.status.toLowerCase() %>"><%= item.status %></span></div><p><%= item.media_name || item.media_file_hint %> · Starts <%= formatDate(item.automation_start_at,settings.timezone) %></p><% if (item.error) { %><div class="inline-error"><%= item.error %></div><% } %><% if (item.warnings?.length) { %><div class="inline-warning"><%= item.warnings.join(' · ') %></div><% } %><% if (item.youtube_url) { %><a class="result-link" href="<%= item.youtube_url %>" target="_blank" rel="noopener">Open on YouTube ↗</a><% } %></div><div class="queue-actions"><% if (!['UPLOADED','UPLOADING'].includes(item.status)) { %><a class="icon-btn" href="/app/uploads/<%= item.id %>/edit" title="Edit">✎</a><form method="post" action="/app/uploads/<%= item.id %>/toggle"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="icon-btn" title="Pause or enable"><%= item.enabled ? 'Ⅱ' : '▶' %></button></form><form method="post" action="/app/uploads/<%= item.id %>/retry"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="icon-btn" title="Retry">↻</button></form><form method="post" action="/app/uploads/<%= item.id %>/delete" data-confirm="Delete this queued upload?"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="icon-btn danger" title="Delete">×</button></form><% } %></div></article><% }) %><% if (!uploads.length) { %><div class="empty-state">No uploads are scheduled yet.</div><% } %></div>
    </section>

    <section id="settings" class="panel"><div class="section-heading"><div><p class="eyebrow">Automation guardrails</p><h2>Worker settings</h2></div></div><form class="form-grid form-grid-4" method="post" action="/app/settings"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><label class="toggle-field"><input type="checkbox" name="automationEnabled" <%= settings.automation_enabled ? 'checked' : '' %>><span><i></i>Automation enabled</span></label><label><span>Daily upload limit</span><input type="number" name="maximumUploadsPerDay" min="1" max="50" value="<%= settings.maximum_uploads_per_day %>"></label><label><span>Minimum gap (minutes)</span><input type="number" name="minimumGapMinutes" min="0" max="1440" value="<%= settings.minimum_gap_minutes %>"></label><label><span>Maximum attempts</span><input type="number" name="maxAttempts" min="1" max="10" value="<%= settings.max_attempts %>"></label><label><span>Retry delay (minutes)</span><input type="number" name="retryDelayMinutes" min="1" max="1440" value="<%= settings.retry_delay_minutes %>"></label><label><span>Timezone</span><input name="timezone" value="<%= settings.timezone %>"></label><label><span>Window start</span><input type="time" name="uploadWindowStart" value="<%= timeValue(settings.upload_window_start, '00:00') %>"></label><label><span>Window end</span><input type="time" name="uploadWindowEnd" value="<%= timeValue(settings.upload_window_end, '23:59') %>"></label><label><span>Default visibility</span><select name="defaultVisibility"><% ['PRIVATE','UNLISTED','PUBLIC','SCHEDULE'].forEach(v => { %><option value="<%= v %>" <%= settings.default_visibility === v ? 'selected' : '' %>><%= v %></option><% }) %></select></label><label><span>Default audience</span><select name="defaultAudience"><option value="NOT_MADE_FOR_KIDS" <%= settings.default_audience === 'NOT_MADE_FOR_KIDS' ? 'selected' : '' %>>Not made for kids</option><option value="MADE_FOR_KIDS" <%= settings.default_audience === 'MADE_FOR_KIDS' ? 'selected' : '' %>>Made for kids</option></select></label><label><span>Default category ID</span><input name="defaultCategory" value="<%= settings.default_category %>"></label><label><span>Default language</span><input name="defaultLanguage" value="<%= settings.default_language %>"></label><div class="span-4 form-actions"><button class="btn btn-primary" type="submit">Save settings</button></div></form></section>

    <section id="activity" class="panel"><div class="section-heading"><div><p class="eyebrow">Evidence trail</p><h2>Activity & errors</h2></div></div><div class="timeline"><% logs.forEach(log => { %><article class="timeline-item timeline-<%= log.level %>"><span></span><div><strong><%= log.message %></strong><small><%= formatDate(log.created_at,settings.timezone) %></small><% if (log.details?.screenshot) { %><a href="/app/screenshots/<%= log.details.screenshot %>">Download failure screenshot</a><% } %></div></article><% }) %><% if (!logs.length) { %><div class="empty-state">No activity recorded yet.</div><% } %></div></section>
  </main>
</div>
<script src="/assets/cinematic-login.js?v=20260722-dashboard-fix" defer></script>
<%- include('partials/footer') %>
