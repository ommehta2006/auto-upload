<%- include('partials/head') %>
<%- include('partials/nav') %>
<main class="connect-shell">
  <div>
    <%- include('partials/flash') %>
    <section class="connect-card">
      <div class="connect-copy">
        <p class="eyebrow">One-time secure connection</p>
        <h1>Open YouTube Studio in the remote browser.</h1>
        <p>The remote browser runs on the backend server. Enter Google credentials only inside YouTube or Google pages. YouTubePilot saves encrypted browser session state, not your password.</p>
        <ol>
          <li>Open the remote studio.</li>
          <li>The backend browser opens <strong>studio.youtube.com</strong> directly.</li>
          <li>Complete any Google login, OTP, CAPTCHA, channel selection, or verification prompt shown there.</li>
          <li>Return here and save the encrypted browser session whenever you are ready.</li>
        </ol>
        <div class="warning-box">Saving stores the current remote browser session exactly as it is. The connection window expires at <strong><%= new Date(session.expiresAt).toLocaleTimeString() %></strong>.</div>
      </div>
      <div class="connect-actions">
        <a class="btn btn-primary btn-xl" href="<%= session.remoteUrl %>" target="_blank" rel="noopener">Open remote YouTube Studio</a>
        <form method="post" action="/app/youtube/complete">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-success btn-xl" type="submit">Save encrypted connection</button>
        </form>
        <form method="post" action="/app/youtube/cancel">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-ghost" type="submit">Cancel connection</button>
        </form>
      </div>
    </section>
  </div>
</main>
<%- include('partials/footer') %>
